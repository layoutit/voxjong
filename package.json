{
  "name": "voxjong",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "A 3D CSS Mahjong Solitaire game built with Vue, Vite, and PolyCSS.",
  "homepage": "https://voxjong.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LayoutitStudio/voxjong.git"
  },
  "bugs": {
    "url": "https://github.com/LayoutitStudio/voxjong/issues"
  },
  "scripts": {
    "build": "vite build",
    "audit": "npm audit --omit=dev --audit-level=moderate",
    "audit:all": "npm audit --omit=dev",
    "check": "npm run test && npm run build",
    "clean": "rm -rf dist .vite",
    "dev": "vite dev",
    "generate": "npm run build",
    "preview": "vite preview",
    "test": "vitest run"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.7",
    "vite": "^7.3.5",
    "vitest": "^3.2.6"
  },
  "keywords": [
    "mahjong",
    "mahjong-solitaire",
    "voxels",
    "3d-css",
    "vue",
    "vite",
    "puzzle-game"
  ],
  "author": "Layoutit",
  "license": "GPL-3.0-or-later",
  "engines": {
    "node": ">=22.12.0",
    "npm": ">=10"
  },
  "dependencies": {
    "@layoutit/polycss": "^0.2.7",
    "animejs": "^4.5.0",
    "vue": "^3.5.38"
  }
}
